rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Counts — lecture publique, écriture authentifiée uniquement
    match /counts/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Votes — chaque user lit/écrit uniquement son propre doc
    match /votes/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
