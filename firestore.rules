rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Counts — lecture publique, écriture authentifiée (vote normal)
    // ou ouverte pour les ajustements admin (pénalités)
    match /counts/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // Votes — chaque user écrit son propre doc à la création
    // Lecture/suppression/mise à jour ouvertes pour le tableau de bord admin
    // (protégé par mot de passe côté app, pas par les règles Firestore)
    match /votes/{uid} {
      allow read, delete, update: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
    }

    // Device fingerprint locks — empêche un même appareil de voter
    // plusieurs fois, même en navigation privée (où uid change à chaque fois)
    match /deviceVotes/{fingerprintId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if true; // admin peut débloquer un appareil si besoin
      allow update: if false;
    }

    // Tentatives refusées — log des essais de double-vote détectés,
    // utile pour identifier les tricheurs qui changent juste de nom
    match /rejectedAttempts/{id} {
      allow read, delete: if true;
      allow create: if request.auth != null;
      allow update: if false;
    }
  }
}
