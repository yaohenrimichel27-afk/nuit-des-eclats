rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Counts — lecture publique, écriture authentifiée uniquement
    match /counts/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Votes — chaque user écrit son propre doc à la création
    // Lecture/suppression ouvertes pour permettre le tableau de bord admin
    // (protégé par mot de passe côté app, pas par les règles Firestore)
    match /votes/{uid} {
      allow read, delete: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if false;
    }
  }
}
